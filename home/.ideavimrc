source ~/.vimrc

" idea 插件设置 surround
" set surround

set which-key

" idea 插件设置 easymotion
" prefix f <char> 查找字符
" prefix j 向上行
" prefix k 向下行
" prefix w 单词查找
set easymotion
map <leader> <Plug>(easymotion-prefix)

set NERDTree

" https://github.com/magidc/ideavim-anyobject/blob/release/README.md
" vi(a) 选中参数
" vi(f) 选中函数 or lambda
" vi(c) 选中类
" vi(m) 选中匿名
" vi(v) 选中变量
" vi(l) 选中循环
" vi(i) 选中集合(collection)
" vi(x)
" vi(g) 字符类型
" vi(o) 选中括号
" vi(d) 选中文档
" vi(k) 选中注释
set anyobject

" 设置复制时高亮
set highlightedyank

" 设置共享剪贴板
set clipboard+=ideaput

" ============= g 命令强调移动
" 文件内移动
" 移动: 下一个方法
nmap gn <action>(MethodDown)
" 移动: 上一个方法
nmap gm <action>(MethodUp)
" 跳转: 返回
nmap gh <action>(Back)
" 跳转: 前进
nmap gl <action>(Forward)

" 跳转: 跳转定义
nmap gd <action>(GotoDeclaration)
" 跳转: 跳转用法
nmap gu <action>(GotoDeclaration)
" 跳转: 跳转测试
nmap gt <action>(GotoTest)
" 跳转: 跳转下一个错误
nmap ge <action>(GotoNextError)
" 跳转: 跳转实现
nmap ga <action>(GotoImplementation)
" 跳转: 跳转文件在目录中的位置
nmap gf <action>(SelectInProjectView)
" 跳转: 跳转 super (接口)
nmap gs <action>(GotoSuperMethod)

" ============= leader 命令强调显示
" 显示: 文件结构
nmap <leader>o <action>(FileStructurePopup)
" 显示: 结构
nmap <leader>s <action>(ActivateStructureToolWindow)
" 显示: 书签
nmap <leader>b <action>(ActivateBookmarksToolWindow)
" 显示: 类型继承层次结构
nmap <leader>t <action>(TypeHierarchy)
" 显示: 调用层次
nmap <leader>c <action>(CallHierarchy)
" 显示: 代码补全 > 基本 / vscode: 触发建议 / command/ctrl + i
" nmap <leader>i <action>(CodeCompletion)
" 显示: 代码 > 生成
nmap <leader>g <action>(Vcs.ShowTabbedFileHistory)
" 显示: 其他 > 显示上下文操作
nmap <leader>e <action>(ShowIntentionActions)
" 显示: 折叠 > 折叠代码块
nmap <leader>j <action>(ExpandRegion)
" 显示: 折叠 > 折叠代码块
nmap <leader>k <action>(CollapseRegion)
" 列选择模式
" noremap sv <C-v>
" 显示: 参数信息
nmap <leader>p <action>(ParameterInfo)
" 显示: 文档/描述
nmap <leader>d <action>(QuickJavaDoc)
" 显示: 显示快速实现
nmap <leader>i <action>(QuickImplementations)

nmap <PageUp> <action>(PreviousTab)
nmap <PageDown> <action>(NextTab)

" ===================== s 命令强调动作
" 复制引用
nmap sc <action>(CopyReference)
nnoremap sj mzJ\z`

" ===================== t 命令候补
